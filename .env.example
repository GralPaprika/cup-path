# RapidAPI World Football Ranking
RAPIDAPI_KEY=
RAPIDAPI_HOST=world-football-ranking.p.rapidapi.com

# Vercel Blob — linked store adds BLOB_STORE_ID (+ OIDC on Vercel).
# For local/scripts outside Vercel, use BLOB_READ_WRITE_TOKEN instead.
BLOB_READ_WRITE_TOKEN=

# Protect cron endpoints (Vercel sets this automatically for cron jobs)
CRON_SECRET=
